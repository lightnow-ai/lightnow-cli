{
  "name": "io.lightnow.example/memory",
  "version": "1.0.0",
  "description": "A runnable stdio MCP server example for validating LightNow CLI publish and sync workflows.",
  "author": {
    "name": "LightNow",
    "email": "support@lightnow.ai"
  },
  "license": "MIT",
  "homepage": "https://docs.lightnow.ai/reference/cli",
  "keywords": ["mcp", "server", "example", "stdio"],
  "transport": {
